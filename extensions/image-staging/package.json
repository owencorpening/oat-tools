{
  "name": "oat-image-staging",
  "publisher": "owencorpening",
  "displayName": "OAT Image Staging",
  "description": "Owen's Applied Thinking image staging and placement panel for VS Code",
  "version": "0.1.0",
  "engines": { "vscode": "^1.75.0" },
  "categories": ["Other"],
  "main": "./extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "oat-image-staging",
          "title": "OAT Image Staging",
          "icon": "media/camera.svg"
        }
      ]
    },
    "views": {
      "oat-image-staging": [
        {
          "type": "webview",
          "id": "oatImages.panel",
          "name": "Staged Images"
        }
      ]
    },
    "commands": [
      {
        "command": "oatImages.refreshPanel",
        "title": "OAT Images: Refresh Image Panel",
        "icon": "$(refresh)"
      },
      {
        "command": "oatImages.createReviewNeed",
        "title": "OAT Images: Create Review Image Need",
        "icon": "$(note)"
      },
      {
        "command": "oatImages.intakeLocalFile",
        "title": "OAT Images: Intake Local File",
        "icon": "$(file-add)"
      },
      {
        "command": "oatImages.intakeUrl",
        "title": "OAT Images: Intake URL",
        "icon": "$(link)"
      },
      {
        "command": "oatImages.listOpenNeeds",
        "title": "OAT Images: List Open Image Needs"
      },
      {
        "command": "oatImages.listStagedAssets",
        "title": "OAT Images: List Staged Notebook Images"
      },
      {
        "command": "oatImages.listPlannedPlacements",
        "title": "OAT Images: List Planned Image Placements"
      },
      {
        "command": "oatImages.preparePlannedPlacementRun",
        "title": "OAT Images: Prepare Planned Placement Run",
        "icon": "$(clippy)"
      },
      {
        "command": "oatImages.executePlannedPlacementRun",
        "title": "OAT Images: Execute Planned Placement Run",
        "icon": "$(run)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "oatImages.refreshPanel",
          "when": "view == oatImages.panel",
          "group": "navigation"
        },
        {
          "command": "oatImages.intakeLocalFile",
          "when": "view == oatImages.panel",
          "group": "navigation"
        },
        {
          "command": "oatImages.intakeUrl",
          "when": "view == oatImages.panel",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "oatImages.preparePlannedPlacementRun",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        },
        {
          "command": "oatImages.executePlannedPlacementRun",
          "when": "resourceLangId == markdown",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "oatImages.createReviewNeed",
          "when": "resourceLangId == markdown",
          "group": "oat"
        }
      ]
    },
    "configuration": {
      "title": "OAT Image Staging",
      "properties": {
        "oatImages.imagesRepoPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the local images repo. Defaults to ~/dev/images."
        },
        "oatImages.unsplashAccessKey": {
          "type": "string",
          "default": "",
          "description": "Unsplash API Access Key for thumbnail previews."
        },
        "oatImages.ledgerApiUrl": {
          "type": "string",
          "default": "",
          "description": "Optional HTTP API base URL for writing image notebook records."
        },
        "oatImages.ledgerApiToken": {
          "type": "string",
          "default": "",
          "description": "Optional bearer token for oatImages.ledgerApiUrl."
        }
      }
    }
  }
}
